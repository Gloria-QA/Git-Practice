    {
      "name": "Transfers and Reversal",
      "item": [
        {
          "name": "Create Transfer for Reversal",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('run_id', Date.now());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const body = pm.response.json();",
                  "pm.environment.set('reversal_reference', body.transactionId.replace('TRF-', ''));",
                  "pm.expect(body.status).to.eql('SUCCESS');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"TRF-REV-{{run_id}}\",\n  \"accountNumber\": \"1000000001\",\n  \"bankCode\": \"044\",\n  \"amount\": 300,\n  \"narration\": \"Transfer to reverse during QA session\"\n}"
            },
            "url": {
              "raw": "{{local_base_url}}/api/v1/transfers",
