      "name": "Auth",
      "item": [
        {
          "name": "Login Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property('access_token');",
                  "pm.environment.set('auth_token', body.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_password}}\"\n}"
            },
            "url": {
              "raw": "{{local_base_url}}/api/v1/auth/login",
              "host": [
                "{{local_base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
